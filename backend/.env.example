# ──────────────────────────────────────────
#  Pictionary – Backend environment variables
#  Copy this file to .env and adjust the values.
# ──────────────────────────────────────────

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Allowed CORS origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

# Game settings
ROUND_TIME=60           # seconds per drawing turn
MAX_PLAYERS=8           # max players per room
MIN_PLAYERS=2           # min players required to start
ROUNDS_PER_PLAYER=1     # how many times each player draws

# Hint timing (fraction of turn time remaining when each hint is revealed)
HINT_FIRST_PCT=0.50
HINT_SECOND_PCT=0.25
